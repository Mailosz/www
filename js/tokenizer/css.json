{
    "default": {
        "begin": [{
            "on": "blockEnd"
        }],
        "default": true,
        "set": {
            "previous-state": "",
            "quote-type": null
        }
    },
    "atRule": {
        "begin": {
            "on": ["default", "selector"],
            "by": "@"
        }
    },
    "selector": {
        "begin": [{
            "on": ["default"],
            "by": ""
        }]
    },
    "blockStart": {
        "begin": {
            "on": ["selector", "atRule"],
            "by": "{"
        }
    },
    "block": {
        "begin": {
            "on": ["blockStart", "semicolon"]
        }
    },
    "blockEnd": {
        "begin": {
            "on": ["block"],
            "by": "}"
        }
    },
    "propertyOrSelector": {
        "begin": [{
            "on": ["block", "semicolon"]
        }]
    },
    "semicolon":{
        "begin": {
            "on": ["value", "valueQuoteEnd"],
            "by": ";"
        }
    },
    "colon": {
        "begin": [{
            "on": "propertyOrSelector",
            "by": ":"
        }]
    },
    "value": {
        "begin": [{
            "on": "colon"
        }]
    },
    "valueQuote": {
        "begin": [{
            "on": ["value"],
            "by": ["\""],
            "set": {
                "quote-type": "\""
            }
        },{
            "on": ["value"],
            "by": ["'"],
            "set": {
                "quote-type": "'"
            }
        },{
            "on": ["valueQuoteEscape"]
        }]
    },
    "valueQuoteEnd": {
        "begin": [{
            "on": ["valueQuote"],
            "by": ["\""],
            "when": {
                "quote-type": "\""
            }
        },{
            "on": ["valueQuote"],
            "by": ["'"],
            "when": {
                "quote-type": "'"
            }
        }],
        "set": {
            "quote-type": null
        }
    },
    "valueQuoteEscape": {
        "begin": {
            "on": "valueQuote",
            "by": {"regex": "\\\\."}
        }
    },
    
    "comment": {
        "until": {
            "by": "*/"
        },
        "begin": [{
            "by": "/*",
            "everywhere": true,
            "set": {
                "previous-state": ""
            }
        }]
    }
}